# ══════════════════════════════════════════════════════════════
# NetSentinel — .gitignore
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# DATA FILES
# Raw dataset (downloaded, not generated by us)
# Processed data (reproducible via pipeline)
# ──────────────────────────────────────────────────────────────
data/raw/
data/processed/*.csv
data/processed/*.pkl
data/processed/*.h5
data/processed/*.parquet

# Keep small documentation files
!data/processed/cleaning_report.json

# ──────────────────────────────────────────────────────────────
# MODEL ARTIFACTS
# Trained models (reproducible via training scripts)
# ──────────────────────────────────────────────────────────────
*.h5
*.hdf5
*.pkl
*.joblib
*.pt
*.pth
*.onnx
saved_models/

# ──────────────────────────────────────────────────────────────
# MLFLOW
# Experiment tracking logs (local, reproducible)
# ──────────────────────────────────────────────────────────────
mlruns/
mlartifacts/

# ──────────────────────────────────────────────────────────────
# PYTHON
# Virtual environment, cache, compiled files
# ──────────────────────────────────────────────────────────────
venv/
env/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.eggs/

# ──────────────────────────────────────────────────────────────
# JUPYTER NOTEBOOKS
# Checkpoint files (auto-saved drafts)
# ──────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ──────────────────────────────────────────────────────────────
# IDE / EDITOR
# Configuration files specific to your machine
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ──────────────────────────────────────────────────────────────
# OS FILES
# System-generated junk
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────────────────────
# DOCKER
# Runtime files (not config)
# ──────────────────────────────────────────────────────────────
docker/tmp/
*.log

# ──────────────────────────────────────────────────────────────
# ENVIRONMENT / SECRETS
# API keys, credentials, local config
# ──────────────────────────────────────────────────────────────
.env
.env.local
.env.production
secrets/
*.key
*.pem

# ──────────────────────────────────────────────────────────────
# GENERATED IMAGES
# Charts and plots (reproducible via notebooks)
# Keep if you want them on GitHub, ignore if too many
# ──────────────────────────────────────────────────────────────
# notebooks/*.png
# Uncomment the line above if you don't want chart images tracked

# ──────────────────────────────────────────────────────────────
# MISC
# Temporary files, archives, large binaries
# ──────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.rar
*.7z
tmp/
temp/
*.bak
*.tmp